generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?  @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  setups    Setup[]
}

model Account {
  id        String   @id @default(uuid())
  name      String
  balance   Decimal
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  trades Trade[]

  @@index([userId])
}

model Trade {
  id           String   @id @default(uuid())
  symbol       String
  side         Side

  entry        Decimal
  exit         Decimal?

  stopLoss     Decimal
  takeProfit   Decimal?

  size         Decimal

  risk         Decimal?
  reward       Decimal?
  rr           Decimal?

  pnl          Decimal?
  fee          Decimal?
  balanceAfter Decimal?

  status       TradeStatus @default(OPEN)
  result       Result?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  setupId String?
  setup   Setup? @relation(fields: [setupId], references: [id], onDelete: SetNull)

  tags TradeTag[]

  @@index([accountId, createdAt])
}

model Setup {
  id          String   @id @default(uuid())
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  trades Trade[]
}

model Tag {
  id     String     @id @default(uuid())
  name   String     @unique
  trades TradeTag[]
}

model TradeTag {
  tradeId String
  tagId   String

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([tradeId, tagId])
}

enum Side {
  LONG
  SHORT
}

enum Result {
  WIN
  LOSS
  BE
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
}